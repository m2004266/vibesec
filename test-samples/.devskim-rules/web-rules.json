[
  {
    "name": "Python command execution with shell=True",
    "id": "VS-CUSTOM-001",
    "description": "subprocess is running with shell=True, which can lead to command injection.",
    "recommendation": "Use shell=False and pass arguments as a list.",
    "applies_to": [
      "python"
    ],
    "severity": "critical",
    "tags": [
      "security",
      "command-injection",
      "python"
    ],
    "patterns": [
      {
        "pattern": "subprocess\\.(run|call|Popen)\\s*\\([^\\n]*shell\\s*=\\s*True",
        "type": "regex"
      }
    ]
  },
